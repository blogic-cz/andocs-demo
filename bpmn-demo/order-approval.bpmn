<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_2" targetNamespace="http://bpmn.io/schema/bpmn">
  <bpmn:process id="OrderApproval" isExecutable="false">
    <bpmn:startEvent id="StartEvent_Order" name="Order created">
      <bpmn:outgoing>Flow_A</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:userTask id="Task_Check" name="Check order">
      <bpmn:incoming>Flow_A</bpmn:incoming>
      <bpmn:outgoing>Flow_B</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="Gateway_Approved" name="Approved?">
      <bpmn:incoming>Flow_B</bpmn:incoming>
      <bpmn:outgoing>Flow_C</bpmn:outgoing>
      <bpmn:outgoing>Flow_D</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="Task_Ship" name="Ship package">
      <bpmn:incoming>Flow_C</bpmn:incoming>
      <bpmn:outgoing>Flow_E</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="EndEvent_Shipped" name="Shipped">
      <bpmn:incoming>Flow_E</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:endEvent id="EndEvent_Cancelled" name="Cancelled">
      <bpmn:incoming>Flow_D</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_A" sourceRef="StartEvent_Order" targetRef="Task_Check" />
    <bpmn:sequenceFlow id="Flow_B" sourceRef="Task_Check" targetRef="Gateway_Approved" />
    <bpmn:sequenceFlow id="Flow_C" name="Yes" sourceRef="Gateway_Approved" targetRef="Task_Ship" />
    <bpmn:sequenceFlow id="Flow_D" name="No" sourceRef="Gateway_Approved" targetRef="EndEvent_Cancelled" />
    <bpmn:sequenceFlow id="Flow_E" sourceRef="Task_Ship" targetRef="EndEvent_Shipped" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_2">
    <bpmndi:BPMNPlane id="BPMNPlane_2" bpmnElement="OrderApproval">
      <bpmndi:BPMNShape id="StartEvent_Order_di" bpmnElement="StartEvent_Order">
        <dc:Bounds x="120" y="120" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_Check_di" bpmnElement="Task_Check">
        <dc:Bounds x="220" y="98" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_Approved_di" bpmnElement="Gateway_Approved" isMarkerVisible="true">
        <dc:Bounds x="370" y="113" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_Ship_di" bpmnElement="Task_Ship">
        <dc:Bounds x="470" y="98" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_Shipped_di" bpmnElement="EndEvent_Shipped">
        <dc:Bounds x="640" y="120" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_Cancelled_di" bpmnElement="EndEvent_Cancelled">
        <dc:Bounds x="480" y="230" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_A_di" bpmnElement="Flow_A">
        <di:waypoint x="156" y="138" />
        <di:waypoint x="220" y="138" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_B_di" bpmnElement="Flow_B">
        <di:waypoint x="320" y="138" />
        <di:waypoint x="370" y="138" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_C_di" bpmnElement="Flow_C">
        <di:waypoint x="420" y="138" />
        <di:waypoint x="470" y="138" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_D_di" bpmnElement="Flow_D">
        <di:waypoint x="395" y="163" />
        <di:waypoint x="395" y="248" />
        <di:waypoint x="480" y="248" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_E_di" bpmnElement="Flow_E">
        <di:waypoint x="570" y="138" />
        <di:waypoint x="640" y="138" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
